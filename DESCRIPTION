Package: mlstudy
Title: Machine Learning Self-Study: Classification Model Comparison
Version: 0.1.0
Authors@R: c(
        person("Aksel", "J", , "ajens22@student.aau.dk", role = c("aut", "cre")),
        person("Alex", "G", , "agrege22@student.aau.dk", role = c("aut" )),
        person("Lisa", "R", , "lrijkh22@student.aau.dk", role = c("aut")),
